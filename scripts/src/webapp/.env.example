# Firestore (Firebase Admin) credentials for the local API server (server/api.cjs)
# and the export script (export.js). Copy to .env and fill in.
# NEVER commit .env or a real key — files named *firebase-adminsdk*.json are gitignored.

# Option A — local dev: path to a service-account JSON (resolved from the webapp dir).
GOOGLE_APPLICATION_CREDENTIALS=../../../docs/webapp/restaurant-robocup-2026-firebase-adminsdk-fbsvc-25f9639eb3.json

# Option B — deploy/CI: the service-account JSON inlined on a single line (takes precedence).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"restaurant-robocup-2026",...}

# Optional overrides
# FIREBASE_PROJECT_ID=restaurant-robocup-2026
# WEBAPP_DEFAULT_ROLE=manager
